# Example environment variables for development
# Replace values before copying to .env

# Example DATABASE_URL (Postgres)
DATABASE_URL=postgres://postgres:password@localhost:5432/up_train_rubyon_rails_development

# Alternatively set individual PG variables
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=up_train_rubyon_rails_development

# Rails environment
RAILS_ENV=development

# Example production DB password env used in config/database.yml
UP_TRAIN_RUBYON_RAILS_DATABASE_PASSWORD=your_production_db_password
